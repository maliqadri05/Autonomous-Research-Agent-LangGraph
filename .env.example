# API Keys (Optional for open-source models)
HUGGINGFACE_API_TOKEN=your_huggingface_token_here_optional
LANGCHAIN_API_KEY=your_langchain_api_key_here_optional

# Optional: LangSmith Tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=research-agent

# Hugging Face Model Configuration
# Popular options:
# - mistralai/Mistral-7B-Instruct-v0.2 (recommended, 7B params)
# - meta-llama/Llama-2-7b-chat-hf (requires HF token)
# - google/flan-t5-xxl (11B params, good for summarization)
# - tiiuae/falcon-7b-instruct
LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# Embedding Model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Generation Parameters
TEMPERATURE=0.7
MAX_NEW_TOKENS=2048

# Device (cuda for GPU, cpu for CPU, mps for Apple Silicon)
DEVICE=cuda

# Vector Store Configuration
VECTOR_STORE_PATH=./data/vector_store
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Research Configuration
MAX_SEARCH_RESULTS=5
MAX_ITERATIONS=10
